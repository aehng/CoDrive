<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/settingsBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_back"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_previous" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/settings_screen_title"
            android:textAppearance="@style/TextAppearance.AppCompat.Title" />

        <ImageButton
            android:id="@+id/settingsMenuButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_menu_content_description"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_sort_by_size" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/settingsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/settingsTabLlm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_tab_llm" />

                <Button
                    android:id="@+id/settingsTabVoice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/settings_tab_voice" />

                <Button
                    android:id="@+id/settingsTabStt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/settings_tab_stt" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsLlmSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_llm_section_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_provider_label" />

                <Spinner
                    android:id="@+id/settingsProviderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_api_key_label" />

                <EditText
                    android:id="@+id/settingsApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_api_key_hint"
                    android:inputType="textPassword" />

                <TextView
                    android:id="@+id/settingsKeyPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_key_preview_default" />

                <Button
                    android:id="@+id/settingsLoadModelsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_load_models_button" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_model_list_label" />

                <Spinner
                    android:id="@+id/settingsModelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_model_label" />

                <EditText
                    android:id="@+id/settingsModelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_model_hint"
                    android:inputType="text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_agentic_section_title"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/settingsAgenticEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_agentic_enabled" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_agentic_iterations_label" />

                <SeekBar
                    android:id="@+id/settingsAgenticIterationsSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="9" />

                <TextView
                    android:id="@+id/settingsAgenticIterationsValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="3" />

                <CheckBox
                    android:id="@+id/settingsHistoryEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_history_enabled" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_history_depth_label" />

                <SeekBar
                    android:id="@+id/settingsHistoryDepthSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="20" />

                <TextView
                    android:id="@+id/settingsHistoryDepthValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="4" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_dual_routing_section_title"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/settingsDualRoutingEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_dual_routing_enabled" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_dual_routing_ratio_label" />

                <SeekBar
                    android:id="@+id/settingsDualRoutingGroqSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100" />

                <TextView
                    android:id="@+id/settingsDualRoutingRatioValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Groq 20% / Gemini 80%" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsVoiceSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_voice_section_title"
                    android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_locale_label" />

            <EditText
                android:id="@+id/settingsSttLocaleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_stt_locale_hint"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_tts_locale_label" />

            <EditText
                android:id="@+id/settingsTtsLocaleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_tts_locale_hint"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_tts_rate_label" />

            <SeekBar
                android:id="@+id/settingsTtsRateSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="60" />

            <TextView
                android:id="@+id/settingsTtsRateValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1.00" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_tts_pitch_label" />

            <SeekBar
                android:id="@+id/settingsTtsPitchSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="60" />

            <TextView
                android:id="@+id/settingsTtsPitchValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1.00" />

            <CheckBox
                android:id="@+id/settingsSherpaEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Use Sherpa Offline Voice Engines" />

            <CheckBox
                android:id="@+id/settingsBargeInEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_barge_in_enabled" />

            <CheckBox
                android:id="@+id/settingsSpeakerphonePreferred"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_speakerphone_preferred" />

            <Button
                android:id="@+id/settingsTestVoiceButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_test_voice_button" />

                <Button
                    android:id="@+id/settingsResetVoiceButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_reset_voice_button" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsSttSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_stt_tuning_section_title"
                    android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_threshold_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_threshold_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsSpeechThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1800" />

            <TextView
                android:id="@+id/settingsSpeechThresholdValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="600" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_vad_threshold_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_vad_threshold_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsVadThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="70" />

            <TextView
                android:id="@+id/settingsVadThresholdValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0.50" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_min_voiced_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_min_voiced_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsMinVoicedSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="720" />

            <TextView
                android:id="@+id/settingsMinVoicedValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="180 ms" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_silence_end_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_silence_end_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsSilenceEndSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="780" />

            <TextView
                android:id="@+id/settingsSilenceEndValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="250 ms" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_vad_window_size_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_vad_window_size_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsVadWindowSizeSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="768" />

            <TextView
                android:id="@+id/settingsVadWindowSizeValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="512" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_stt_vad_threads_label" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_stt_vad_threads_help"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/settingsVadThreadsSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3" />

            <TextView
                android:id="@+id/settingsVadThreadsValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_command_delay_label" />

            <SeekBar
                android:id="@+id/settingsCommandDelaySeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="4900" />

                <TextView
                    android:id="@+id/settingsCommandDelayValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1500 ms" />
            </LinearLayout>

            <Button
                android:id="@+id/settingsSaveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_save_button" />

            <TextView
                android:id="@+id/settingsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_status_idle" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
